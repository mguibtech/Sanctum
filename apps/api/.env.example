# Sanctum API environment

# Local development with docker-compose from repo root
DATABASE_URL="postgresql://sanctum:sanctum@localhost:55432/sanctum?schema=public"
REDIS_URL="redis://localhost:6379"

# Remote examples
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# JWT
JWT_SECRET="change_me"
JWT_REFRESH_SECRET="change_me_too"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="30d"

# API.Bible
BIBLE_API_KEY="your_api_bible_key"
BIBLE_ID_PT="a0720b1f-f3b3-4a1f-90eb-7e29e4ec0c04"

# Optional integrations
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
FCM_SERVER_KEY=""

# App
PORT=3000
NODE_ENV="development"
