# ===== API =====
API_PORT=3000
API_CORS_ORIGIN="http://localhost:3000,http://localhost:8081"

# ===== REDIS (opcional) =====
REDIS_URL="redis://localhost:6379"

# ===== RATE LIMITING =====
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ===== EMAIL (opcional) =====
MAIL_HOST="smtp.gmail.com"
