# ===== DATABASE =====
DATABASE_URL="postgresql://user:password@localhost:5432/sanctum"

# ===== JWT =====
JWT_SECRET="sua_secret_key_muito_longa_e_aleatoria"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ===== ENVIRONMENT =====
NODE_ENV="development"
